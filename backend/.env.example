# ─────────────────────────────────────────────────────────────
#  Prashiksha — Online Examination System
#  Environment Configuration Template
#
#  Copy this file to .env and fill in your own values.
#  NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── JWT ──────────────────────────────────────────────────────
# Secret key used to sign and verify JSON Web Tokens.
# Generate a strong random string (min 64 chars recommended):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# ── MongoDB ───────────────────────────────────────────────────
# Connection URI for your MongoDB instance.
# Local example:  mongodb://localhost:27017/prashiksha
# Atlas example:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/prashiksha?retryWrites=true&w=majority
MONGODB_URI=your_url

# ── Server ────────────────────────────────────────────────────
# Port the Express server will listen on (default: 3000)
PORT=3000

# Environment: development | production
NODE_ENV=development
